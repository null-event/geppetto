slack:
  - name: "Example Slack Bot"
    token: "xoxb-your-token-here"

lark:
  - name: "Example Lark Bot"
    app_id: "cli_your_app_id"
    app_secret: "your_app_secret"

teams:
  - name: "Example Teams Bot"
    client_id: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
    client_secret: "your-client-secret"

gchat:
  - name: "Example Google Chat Bot"
    service_account_path: "/path/to/service_account.json"
    # Optional: required for file attachments (domain-wide delegation)
    # delegate_user_email: "admin@example.com"
    # Optional: required for space creation (Google Workspace customer ID)
    # customer_id: "C01234abc"

discord:
  - name: "Example Discord Bot"
    # Optional: bot token enables channel/DM/file actions.
    # token: "your-bot-token-here"
    # Optional: webhooks enable spoofed sends (custom username/avatar).
    # At least one of token/webhooks must be set.
    # webhooks:
    #   - name: "#general spoof hook"
    #     url: "https://discord.com/api/webhooks/XXX/YYY"
